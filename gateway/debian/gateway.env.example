# ─────────────────────────────────────────────────────────────────────────────
# EchoSmart Gateway — Environment Configuration
# Copy to /etc/echosmart/gateway.env and fill in your values.
# File must be readable only by root and the 'echosmart' user (chmod 640).
# ─────────────────────────────────────────────────────────────────────────────

# ── Gateway Identity ─────────────────────────────────────────────────────────
# Unique identifier for this gateway device.
# Use lowercase, alphanumeric + hyphens. Example: gw-invernadero-norte-01
GATEWAY_ID=gw-001

# Human-readable name shown in the dashboard
GATEWAY_NAME=Invernadero Principal

# ── Cloud API ────────────────────────────────────────────────────────────────
# URL of the EchoSmart Cloud backend
CLOUD_API_URL=https://api.echosmart.io

# API key generated in the EchoSmart dashboard (Settings → Gateways → Add Key)
CLOUD_API_KEY=your-api-key-here

# ── MQTT Broker ──────────────────────────────────────────────────────────────
# Local Mosquitto broker (installed as part of this package)
MQTT_BROKER=localhost
MQTT_PORT=1883

# Set MQTT credentials if Mosquitto authentication is enabled
# MQTT_USERNAME=echosmart
# MQTT_PASSWORD=your-mqtt-password

# ── Polling & Sync Intervals ─────────────────────────────────────────────────
# How often (seconds) to read sensors
POLLING_INTERVAL=60

# How often (seconds) to sync data to the Cloud
SYNC_INTERVAL=300

# ── Operation Mode ───────────────────────────────────────────────────────────
# Set to "true" to use simulated sensor data (no physical sensors required)
# Useful for testing without hardware
SIMULATION_MODE=false

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────────────────────
# Path to local SQLite database (stores readings for offline operation)
# Default: /var/lib/echosmart/gateway.db
# DB_PATH=/var/lib/echosmart/gateway.db
