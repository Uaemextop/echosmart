# EchoSmart Gateway — Configuración de ejemplo
# Copia a /etc/echosmart/gateway.env y rellena los valores
# O ejecuta: sudo echosmart-gateway-setup

# ── Identidad del gateway ─────────────────────────────────────────────────
GATEWAY_ID=gw-001
GATEWAY_NAME=Invernadero Principal

# ── Backend cloud ─────────────────────────────────────────────────────────
CLOUD_API_URL=https://api.echosmart.io
CLOUD_API_KEY=

# ── MQTT local ────────────────────────────────────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883

# ── Intervalos (segundos) ─────────────────────────────────────────────────
POLLING_INTERVAL=60
SYNC_INTERVAL=300

# ── Modo de operación ─────────────────────────────────────────────────────
# true = sin hardware real (para pruebas / desarrollo)
SIMULATION_MODE=false

# ── Logging ───────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
