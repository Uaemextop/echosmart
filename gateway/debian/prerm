#!/bin/bash
# EchoSmart Gateway — Pre-removal script
set -e

case "$1" in
    remove|upgrade|deconfigure)
        if command -v systemctl &>/dev/null; then
            systemctl stop echosmart-gateway.service || true
            systemctl disable echosmart-gateway.service || true
        fi
        ;;
    failed-upgrade)
        ;;
    *)
        echo "prerm: argumento inesperado '$1'" >&2
        exit 1
        ;;
esac

exit 0
