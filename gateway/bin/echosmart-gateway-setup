#!/usr/bin/env bash
# echosmart-gateway-setup — Interactive first-run wizard for a new EchoSmart kit.
# Installed to /usr/bin/echosmart-gateway-setup by the .deb package.

set -euo pipefail

CONFIG="/etc/echosmart/gateway.env"
SENSORS="/etc/echosmart/sensors.json"

echo "╔══════════════════════════════════════════════╗"
echo "║   EchoSmart Gateway — First-Run Setup        ║"
echo "╚══════════════════════════════════════════════╝"
echo ""

# --- Gateway ID ---
read -rp "Gateway ID [gw-001]: " GW_ID
GW_ID="${GW_ID:-gw-001}"

# --- Gateway name ---
read -rp "Gateway name [Invernadero Principal]: " GW_NAME
GW_NAME="${GW_NAME:-Invernadero Principal}"

# --- Cloud URL ---
read -rp "Cloud API URL [http://localhost:8000]: " CLOUD_URL
CLOUD_URL="${CLOUD_URL:-http://localhost:8000}"

# --- Cloud API key ---
read -rp "Cloud API key (leave blank to skip): " CLOUD_KEY

# --- MQTT ---
read -rp "MQTT broker host [localhost]: " MQTT_HOST
MQTT_HOST="${MQTT_HOST:-localhost}"

# --- Polling ---
read -rp "Sensor polling interval in seconds [60]: " POLL
POLL="${POLL:-60}"

# --- Write config ---
sudo mkdir -p "$(dirname "${CONFIG}")"
sudo tee "${CONFIG}" > /dev/null <<EOF
# EchoSmart Gateway Configuration — generated by setup wizard
GATEWAY_ID=${GW_ID}
GATEWAY_NAME=${GW_NAME}
CLOUD_API_URL=${CLOUD_URL}
CLOUD_API_KEY=${CLOUD_KEY}
MQTT_BROKER=${MQTT_HOST}
MQTT_PORT=1883
POLLING_INTERVAL=${POLL}
SYNC_INTERVAL=300
SIMULATION_MODE=false
LOG_LEVEL=INFO
EOF

# --- Copy default sensors.json if missing ---
if [ ! -f "${SENSORS}" ]; then
    sudo cp /opt/echosmart/sensors.json "${SENSORS}" 2>/dev/null || true
fi

echo ""
echo "✅ Configuration saved to ${CONFIG}"
echo ""
echo "Start the gateway:"
echo "  sudo systemctl enable --now echosmart-gateway"
echo ""
echo "Check status:"
echo "  sudo systemctl status echosmart-gateway"
echo "  echosmart-sysinfo"
echo ""
