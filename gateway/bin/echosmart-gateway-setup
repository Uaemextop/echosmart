#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────
# echosmart-gateway-setup  —  First-boot setup wizard
#
# Guides the operator through initial gateway configuration:
#   1. Set a unique gateway ID
#   2. Configure cloud API endpoint
#   3. Set MQTT broker address
#   4. Optionally enable simulation mode
#   5. Write /etc/echosmart/gateway.env
# ──────────────────────────────────────────────────────────────
set -euo pipefail

CONFIG_DIR="/etc/echosmart"
ENV_FILE="${CONFIG_DIR}/gateway.env"

echo "══════════════════════════════════════════"
echo "  EchoSmart Gateway — Setup Wizard"
echo "══════════════════════════════════════════"
echo ""

# Ensure we run as root (needed for writing to /etc)
if [ "$(id -u)" -ne 0 ]; then
    echo "⚠  This script must be run as root.  Try: sudo $0"
    exit 1
fi

mkdir -p "${CONFIG_DIR}"

read -rp "Gateway ID          [gw-001]      : " GW_ID
GW_ID="${GW_ID:-gw-001}"

read -rp "Gateway name        [Invernadero] : " GW_NAME
GW_NAME="${GW_NAME:-Invernadero}"

read -rp "Cloud API URL       [http://cloud.echosmart.io] : " API_URL
API_URL="${API_URL:-http://cloud.echosmart.io}"

read -rp "Cloud API Key       []            : " API_KEY
API_KEY="${API_KEY:-}"

read -rp "MQTT broker address [localhost]   : " MQTT
MQTT="${MQTT:-localhost}"

read -rp "MQTT port           [1883]        : " MQTT_PORT
MQTT_PORT="${MQTT_PORT:-1883}"

read -rp "Polling interval (s)[60]          : " POLL
POLL="${POLL:-60}"

read -rp "Enable simulation?  [no]          : " SIM
case "${SIM,,}" in
    y|yes|true|1) SIM_MODE="true" ;;
    *)            SIM_MODE="false" ;;
esac

cat > "${ENV_FILE}" <<EOF
# EchoSmart Gateway configuration — generated by setup wizard
GATEWAY_ID=${GW_ID}
GATEWAY_NAME=${GW_NAME}
CLOUD_API_URL=${API_URL}
CLOUD_API_KEY=${API_KEY}
MQTT_BROKER=${MQTT}
MQTT_PORT=${MQTT_PORT}
POLLING_INTERVAL=${POLL}
SIMULATION_MODE=${SIM_MODE}
LOG_LEVEL=INFO
EOF

chmod 640 "${ENV_FILE}"
echo ""
echo "✓ Configuration saved to ${ENV_FILE}"
echo "  Start the gateway with: sudo systemctl start echosmart-gateway"
echo ""
