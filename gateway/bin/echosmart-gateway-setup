#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# EchoSmart Gateway — First-boot configuration wizard
# Installed to /usr/bin/echosmart-gateway-setup by the .deb package.
# ─────────────────────────────────────────────────────────────
set -euo pipefail

CONFIG_DIR="/etc/echosmart"
ENV_FILE="${CONFIG_DIR}/gateway.env"
SERVICE_NAME="echosmart-gateway.service"

banner() {
    echo ""
    echo "╔══════════════════════════════════════════════╗"
    echo "║   EchoSmart Gateway — Setup Wizard  v1.0    ║"
    echo "╚══════════════════════════════════════════════╝"
    echo ""
}

prompt() {
    local var_name="$1" prompt_text="$2" default_val="${3:-}"
    local input
    if [ -n "$default_val" ]; then
        read -rp "  $prompt_text [$default_val]: " input
        eval "$var_name=\"${input:-$default_val}\""
    else
        read -rp "  $prompt_text: " input
        eval "$var_name=\"$input\""
    fi
}

# ── Main ──────────────────────────────────────────────────────
banner

echo "This wizard will configure your EchoSmart gateway."
echo "You can re-run this script at any time to change settings."
echo ""

# 1. Gateway identity
prompt GW_ID   "Gateway ID (e.g. gw-001)" "gw-001"
prompt GW_NAME "Gateway name (human-readable)" "Invernadero Principal"

# 2. Server connection
prompt CLOUD_URL "EchoSmart server URL" "http://localhost:8000"
prompt API_KEY   "API key (from server dashboard)" ""

# 3. MQTT
prompt MQTT_HOST "MQTT broker host" "localhost"
prompt MQTT_PORT "MQTT broker port" "1883"

# 4. Polling
prompt POLL_INT "Sensor polling interval (seconds)" "60"
prompt SYNC_INT "Cloud sync interval (seconds)"     "300"

# 5. Simulation mode
prompt SIM_MODE "Enable simulation mode? (true/false)" "false"

# ── Write configuration ──────────────────────────────────────
echo ""
echo "Writing configuration to ${ENV_FILE} …"

sudo mkdir -p "$CONFIG_DIR"
sudo tee "$ENV_FILE" > /dev/null <<EOF
# EchoSmart Gateway configuration — generated by echosmart-gateway-setup
GATEWAY_ID=${GW_ID}
GATEWAY_NAME=${GW_NAME}
CLOUD_API_URL=${CLOUD_URL}
CLOUD_API_KEY=${API_KEY}
MQTT_BROKER=${MQTT_HOST}
MQTT_PORT=${MQTT_PORT}
POLLING_INTERVAL=${POLL_INT}
SYNC_INTERVAL=${SYNC_INT}
SIMULATION_MODE=${SIM_MODE}
LOG_LEVEL=INFO
EOF
sudo chmod 640 "$ENV_FILE"

echo "Configuration saved."

# ── Enable & start service ───────────────────────────────────
if systemctl list-unit-files | grep -q "$SERVICE_NAME"; then
    echo ""
    read -rp "  Start the gateway service now? [Y/n]: " START
    START="${START:-Y}"
    if [[ "$START" =~ ^[Yy] ]]; then
        sudo systemctl daemon-reload
        sudo systemctl enable "$SERVICE_NAME"
        sudo systemctl restart "$SERVICE_NAME"
        echo "Service started. Check status with: systemctl status $SERVICE_NAME"
    fi
fi

echo ""
echo "✅  Setup complete!  Run 'echosmart-gateway status' to verify."
echo ""
