#!/usr/bin/env bash
# echosmart-gateway-setup — Asistente de configuración inicial del EchoSmart Gateway
# Ejecutar como root una sola vez tras instalar el paquete .deb
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

CONFIG_FILE="/etc/echosmart/gateway.env"
SERVICE_NAME="echosmart-gateway"

banner() {
    echo -e "${CYAN}"
    echo "  ███████╗ ██████╗██╗  ██╗ ██████╗ ███████╗███╗   ███╗ █████╗ ██████╗ ████████╗"
    echo "  ██╔════╝██╔════╝██║  ██║██╔═══██╗██╔════╝████╗ ████║██╔══██╗██╔══██╗╚══██╔══╝"
    echo "  █████╗  ██║     ███████║██║   ██║███████╗██╔████╔██║███████║██████╔╝   ██║   "
    echo "  ██╔══╝  ██║     ██╔══██║██║   ██║╚════██║██║╚██╔╝██║██╔══██║██╔══██╗   ██║   "
    echo "  ███████╗╚██████╗██║  ██║╚██████╔╝███████║██║ ╚═╝ ██║██║  ██║██║  ██║   ██║   "
    echo "  ╚══════╝ ╚═════╝╚═╝  ╚═╝ ╚═════╝ ╚══════╝╚═╝     ╚═╝╚═╝  ╚═╝╚═╝  ╚═╝   ╚═╝   "
    echo -e "${NC}"
    echo -e "${BOLD}  Asistente de Configuración del Gateway EchoSmart v1.0${NC}"
    echo -e "  ─────────────────────────────────────────────────────────"
    echo ""
}

prompt() {
    local label="$1"
    local default="$2"
    local var_name="$3"
    echo -ne "${YELLOW}  ▶ ${label}${NC} [${default}]: "
    read -r input
    eval "${var_name}=\"\${input:-${default}}\""
}

check_root() {
    if [[ "$EUID" -ne 0 ]]; then
        echo -e "${RED}Error: este asistente debe ejecutarse como root (sudo).${NC}" >&2
        exit 1
    fi
}

check_dependencies() {
    echo -e "${CYAN}  Verificando dependencias...${NC}"
    local missing=()
    for dep in python3 mosquitto systemctl; do
        if ! command -v "${dep}" &>/dev/null; then
            missing+=("${dep}")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${RED}  Dependencias faltantes: ${missing[*]}${NC}"
        echo -e "  Instale con: sudo apt install python3 mosquitto"
        exit 1
    fi
    echo -e "${GREEN}  ✓ Dependencias OK${NC}"
}

configure_network() {
    echo ""
    echo -e "${BOLD}  [1/4] Configuración de red del servidor cloud${NC}"
    prompt "URL del backend cloud" "https://api.echosmart.io" CLOUD_API_URL
    prompt "API Key del gateway (obténla en el dashboard)" "" CLOUD_API_KEY
    if [[ -z "${CLOUD_API_KEY}" ]]; then
        echo -e "${YELLOW}  Advertencia: API Key vacía. Deberás configurarla después en ${CONFIG_FILE}${NC}"
    fi
}

configure_gateway() {
    echo ""
    echo -e "${BOLD}  [2/4] Identidad del gateway${NC}"
    local default_id
    default_id="gw-$(hostname | tr '[:upper:]' '[:lower:]' | tr -d ' ')"
    prompt "ID del gateway" "${default_id}" GATEWAY_ID
    prompt "Nombre descriptivo" "Invernadero Principal" GATEWAY_NAME
}

configure_mqtt() {
    echo ""
    echo -e "${BOLD}  [3/4] Configuración MQTT${NC}"
    prompt "Broker MQTT (localhost = usar Mosquitto local)" "localhost" MQTT_BROKER
    prompt "Puerto MQTT" "1883" MQTT_PORT
    prompt "Intervalo de polling de sensores (segundos)" "60" POLLING_INTERVAL
    prompt "Intervalo de sincronización cloud (segundos)" "300" SYNC_INTERVAL
}

write_config() {
    echo ""
    echo -e "${BOLD}  [4/4] Escribiendo configuración...${NC}"
    mkdir -p "$(dirname "${CONFIG_FILE}")"
    cat > "${CONFIG_FILE}" <<EOF
# EchoSmart Gateway — Configuración
# Generado por echosmart-gateway-setup el $(date -u +"%Y-%m-%dT%H:%M:%SZ")

GATEWAY_ID=${GATEWAY_ID}
GATEWAY_NAME=${GATEWAY_NAME}

CLOUD_API_URL=${CLOUD_API_URL}
CLOUD_API_KEY=${CLOUD_API_KEY}

MQTT_BROKER=${MQTT_BROKER}
MQTT_PORT=${MQTT_PORT}

POLLING_INTERVAL=${POLLING_INTERVAL}
SYNC_INTERVAL=${SYNC_INTERVAL}

SIMULATION_MODE=false
LOG_LEVEL=INFO
EOF
    chmod 640 "${CONFIG_FILE}"
    chown root:pi "${CONFIG_FILE}" 2>/dev/null || true
    echo -e "${GREEN}  ✓ Configuración guardada en ${CONFIG_FILE}${NC}"
}

enable_service() {
    echo ""
    echo -e "${CYAN}  Activando y arrancando servicio systemd...${NC}"
    systemctl daemon-reload
    systemctl enable "${SERVICE_NAME}"
    systemctl restart "${SERVICE_NAME}"
    sleep 2
    if systemctl is-active --quiet "${SERVICE_NAME}"; then
        echo -e "${GREEN}  ✓ Servicio ${SERVICE_NAME} activo y funcionando${NC}"
    else
        echo -e "${YELLOW}  Advertencia: el servicio no arrancó correctamente.${NC}"
        echo -e "  Revisa los logs con: journalctl -u ${SERVICE_NAME} -n 50"
    fi
}

summary() {
    echo ""
    echo -e "${GREEN}  ╔══════════════════════════════════════════════════════╗"
    echo -e "  ║       ¡Configuración completada exitosamente!       ║"
    echo -e "  ╚══════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "  ${BOLD}Gateway ID  :${NC} ${GATEWAY_ID}"
    echo -e "  ${BOLD}Nombre      :${NC} ${GATEWAY_NAME}"
    echo -e "  ${BOLD}Cloud URL   :${NC} ${CLOUD_API_URL}"
    echo -e "  ${BOLD}MQTT Broker :${NC} ${MQTT_BROKER}:${MQTT_PORT}"
    echo ""
    echo -e "  Comandos útiles:"
    echo -e "    ${CYAN}echosmart-gateway status${NC}        — Ver estado"
    echo -e "    ${CYAN}echosmart-gateway test-sensors${NC}  — Probar sensores"
    echo -e "    ${CYAN}journalctl -u ${SERVICE_NAME} -f${NC}  — Ver logs en tiempo real"
    echo ""
}

main() {
    banner
    check_root
    check_dependencies
    configure_network
    configure_gateway
    configure_mqtt
    write_config
    enable_service
    summary
}

main "$@"
