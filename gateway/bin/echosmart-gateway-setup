#!/usr/bin/env bash
# EchoSmart Gateway — first-run setup wizard
# Guides the user through initial configuration on a fresh Raspberry Pi.

set -euo pipefail

INSTALL_DIR="/opt/echosmart/gateway"
CONFIG_DIR="/etc/echosmart"
ENV_FILE="${CONFIG_DIR}/gateway.env"

echo "========================================"
echo "  EchoSmart Gateway — Setup Wizard"
echo "========================================"
echo ""

# Ensure running as root
if [ "$(id -u)" -ne 0 ]; then
    echo "This wizard must be run as root (sudo)."
    exit 1
fi

# Create config directory
mkdir -p "$CONFIG_DIR"

# Gateway ID
read -rp "Gateway ID [gw-001]: " GATEWAY_ID
GATEWAY_ID="${GATEWAY_ID:-gw-001}"

# Gateway name
read -rp "Gateway Name [Invernadero Principal]: " GATEWAY_NAME
GATEWAY_NAME="${GATEWAY_NAME:-Invernadero Principal}"

# Cloud API
read -rp "Cloud API URL [http://localhost:8000]: " CLOUD_API_URL
CLOUD_API_URL="${CLOUD_API_URL:-http://localhost:8000}"

read -rp "Cloud API Key []: " CLOUD_API_KEY
CLOUD_API_KEY="${CLOUD_API_KEY:-}"

# MQTT
read -rp "MQTT Broker [localhost]: " MQTT_BROKER
MQTT_BROKER="${MQTT_BROKER:-localhost}"

read -rp "MQTT Port [1883]: " MQTT_PORT
MQTT_PORT="${MQTT_PORT:-1883}"

# Intervals
read -rp "Polling Interval (seconds) [60]: " POLLING_INTERVAL
POLLING_INTERVAL="${POLLING_INTERVAL:-60}"

read -rp "Sync Interval (seconds) [300]: " SYNC_INTERVAL
SYNC_INTERVAL="${SYNC_INTERVAL:-300}"

# Write config
cat > "$ENV_FILE" <<EOF
# EchoSmart Gateway Configuration
# Generated by echosmart-gateway-setup on $(date -Iseconds)

GATEWAY_ID=${GATEWAY_ID}
GATEWAY_NAME=${GATEWAY_NAME}
CLOUD_API_URL=${CLOUD_API_URL}
CLOUD_API_KEY=${CLOUD_API_KEY}
MQTT_BROKER=${MQTT_BROKER}
MQTT_PORT=${MQTT_PORT}
POLLING_INTERVAL=${POLLING_INTERVAL}
SYNC_INTERVAL=${SYNC_INTERVAL}
SIMULATION_MODE=false
LOG_LEVEL=INFO
EOF

chmod 600 "$ENV_FILE"

echo ""
echo "Configuration saved to ${ENV_FILE}"

# Enable hardware interfaces
echo ""
echo "Enabling hardware interfaces..."

# Enable I2C
if command -v raspi-config &>/dev/null; then
    raspi-config nonint do_i2c 0 2>/dev/null || true
    raspi-config nonint do_serial_hw 0 2>/dev/null || true
    raspi-config nonint do_onewire 0 2>/dev/null || true
    echo "  ✔ I2C, UART, 1-Wire enabled"
else
    echo "  ⚠ raspi-config not found — enable I2C, UART, 1-Wire manually"
fi

# Install Python venv if needed
if [ ! -d "${INSTALL_DIR}/venv" ]; then
    echo ""
    echo "Creating Python virtual environment..."
    python3 -m venv "${INSTALL_DIR}/venv"
    "${INSTALL_DIR}/venv/bin/pip" install --quiet -r "${INSTALL_DIR}/requirements.txt"
    echo "  ✔ Virtual environment created"
fi

# Enable and start service
echo ""
echo "Enabling systemd service..."
systemctl daemon-reload
systemctl enable echosmart-gateway.service
systemctl start echosmart-gateway.service

echo ""
echo "========================================"
echo "  Setup complete!"
echo "  Service: systemctl status echosmart-gateway"
echo "  Logs:    journalctl -u echosmart-gateway -f"
echo "  Config:  ${ENV_FILE}"
echo "========================================"
