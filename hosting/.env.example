# ============================================================
# EchoSmart — Hosting Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env or env.txt to version control.
# ============================================================

# --- Domain & Server ---
DOMAIN=echosmart.me
SERVER_IP=0.0.0.0
CPANEL_URL=https://your-server.web-hosting.com:2083

# --- cPanel / SSH Credentials ---
CPANEL_USER=your_cpanel_user
CPANEL_PASSWORD=your_cpanel_password
SSH_PORT=21098
SSH_KEY_FILE=id_rsa
SSH_KEY_PASSPHRASE=your_key_passphrase

# --- WordPress ---
WP_URL=https://echosmart.me
WP_ADMIN_URL=https://echosmart.me/wp-admin/
WP_USER=your_wp_admin_user
WP_PASSWORD=your_wp_admin_password
WP_DB_NAME=eduardoc3677_wp
WP_DB_USER=eduardoc3677_wp
WP_DB_PASSWORD=your_wp_db_password
WP_TABLE_PREFIX=wp_

# --- EchoSmart Backend API ---
ECHOSMART_API_URL=https://api.echosmart.me
ECHOSMART_API_VERSION=v1

# --- SSL ---
SSL_ENABLED=true

# --- Remote Paths (cPanel shared hosting) ---
REMOTE_HOME=/home/eduardoc3677
REMOTE_PUBLIC_HTML=/home/eduardoc3677/public_html
REMOTE_WP_CONTENT=/home/eduardoc3677/public_html/wp-content
