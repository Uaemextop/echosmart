# =============================================
# 6. SMTP (Transactional Email - used by PHP API)
# =============================================
# Primary: PHP mail() → local Exim MTA (no SMTP connection needed)
# Fallback: authenticated SMTP via 127.0.0.1:465 (IPv4 forced)
# IMPORTANT: Email routing MUST be set to LOCAL in cPanel:
#   uapi Email set_always_accept domain=echosmart.me mxcheck=local
# Without this, Exim rejects outgoing mail with "domain not allowed in header From"
SMTP_HOST=mail.echosmart.me
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USER=noreply@echosmart.me
SMTP_PASSWORD=EchoSm@rt2026!
SMTP_FROM_EMAIL=noreply@echosmart.me
SMTP_FROM_NAME=EchoSmart

