# ----- SMTP (Transactional Email) -----
SMTP_HOST=mail.echosmart.me
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USER=noreply@echosmart.me
SMTP_PASSWORD=__SMTP_PASSWORD__
SMTP_FROM_EMAIL=noreply@echosmart.me
SMTP_FROM_NAME=EchoSmart

# ----- EMAIL ACCOUNTS -----
# All email accounts are on mail.echosmart.me
# IMAP: port 993 (SSL) | SMTP: port 465 (SSL)
#
# admin@echosmart.me       — Admin / DMARC reports
# info@echosmart.me        — General inquiries (forwards → admin@)
# support@echosmart.me     — Customer support
# noreply@echosmart.me     — System notifications (SMTP sender)
# enterprise@echosmart.me  — Enterprise inquiries
#
EMAIL_ADMIN_PASSWORD=__EMAIL_ADMIN_PASSWORD__
EMAIL_INFO_PASSWORD=__EMAIL_INFO_PASSWORD__
EMAIL_SUPPORT_PASSWORD=__EMAIL_SUPPORT_PASSWORD__
EMAIL_NOREPLY_PASSWORD=__EMAIL_NOREPLY_PASSWORD__
EMAIL_ENTERPRISE_PASSWORD=__EMAIL_ENTERPRISE_PASSWORD__

# ----- SSL (acme.sh + ZeroSSL) -----
ACME_EMAIL=admin@echosmart.me
CPANEL_API_TOKEN=__CPANEL_API_TOKEN__
# Used by acme.sh dns_cpanel plugin for wildcard cert renewal

# ----- WEBMAIL -----
WEBMAIL_URL=https://business191.web-hosting.com:2096
WEBMAIL_BRANDED_URL=https://echosmart.me/webmail/
